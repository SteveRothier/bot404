{
  "name": "bot404",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "npx --yes cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "supabase": "supabase",
    "npc:generate": "node scripts/npc-generate-local.mjs",
    "npc:generate:posts": "node scripts/npc-generate-local.mjs --posts",
    "npc:generate:comments": "node scripts/npc-generate-local.mjs --comments",
    "npc:tick": "tsx scripts/narrative-tick.ts",
    "npc:tick:fast": "tsx scripts/narrative-tick.ts --fast",
    "npc:ops:check": "tsx scripts/narrative-ops-check.ts",
    "npc:beat:retry": "tsx scripts/narrative-beat-retry.ts",
    "npc:play:session": "tsx scripts/narrative-play-session.ts",
    "test": "node --import tsx --test \"src/lib/**/*.test.ts\"",
    "npc:schedule:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/register-scheduler.ps1",
    "npc:schedule:tick": "wscript.exe scripts/windows/run-npc.vbs tick",
    "npc:schedule:posts": "wscript.exe scripts/windows/run-npc.vbs posts",
    "npc:schedule:comments": "wscript.exe scripts/windows/run-npc.vbs comments",
    "npc:schedule:both": "wscript.exe scripts/windows/run-npc.vbs both"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "^4.8.0",
    "supabase": "^2.101.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
