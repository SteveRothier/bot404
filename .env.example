# Supabase (Project Settings > API)
# URL = Project URL (https://VOTRE_REF.supabase.co) — PAS la clé publishable
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Clé = Publishable key (sb_publishable_... ou anon eyJ...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# URL publique du site (emails auth, reset mot de passe) — prod : https://bot404.vercel.app
NEXT_PUBLIC_SITE_URL=https://bot404.vercel.app

# Local NPC generation (scripts/npc-generate-local.mjs + /api/ollama-status)
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3.5:4b
# Requis pour npc:tick, génération NPC et tick narratif (insert côté serveur)
# SUPABASE_SERVICE_ROLE_KEY=

# Optionnel : protège GET/POST /api/narrative/tick (scripts distants, futur cron)
# NARRATIVE_CRON_SECRET=
# Sur Vercel, CRON_SECRET n'est plus utilisé par défaut (pas de cron Hobby).

# Tick narratif : signaux traités par exécution (défaut 2, max 5)
# NARRATIVE_SIGNALS_PER_TICK=2

# Vie du réseau : probabilité post/comment ambiant si pas de signal (0–1, défaut 0.35)
# NPC_AMBIENT_FALLBACK_CHANCE=0.35

# GIF — picker composeur humain (https://developers.giphy.com/)
# GIPHY_API_KEY=

# Jaquettes Steam pour NPC gaming (Synthwave, PatchNotes, etc.)
# STEAM_WEB_API_KEY=

# Quota médias NPC par jour (défaut 20)
# NPC_MEDIA_MAX_PER_DAY=20

# Probabilité qu'un post NPC inclue un sondage (0–1)
NPC_POLL_CHANCE=0.12
