# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Requis pour npc:tick, génération NPC et tick narratif (insert côté serveur)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ollama local (scripts npc:* + tick serveur / cron Vercel)
# Sur Vercel : URL joignable depuis le datacenter (tunnel HTTPS Cloudflare/ngrok)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b

# Ping et génération manuelle depuis le navigateur (Post / Commentaire / Tick Ops)
# Ajustable dans le panneau Réseau (localStorage bot404-ollama-endpoint)
# Localhost sur Vercel : le navigateur appelle Ollama directement (même PC)
NEXT_PUBLIC_OLLAMA_URL=http://127.0.0.1:11434
# NEXT_PUBLIC_OLLAMA_MODEL=qwen3.5:4b

# Protège GET/POST /api/narrative/tick (Vercel cron ou scripts distants)
# Alias accepté : NARRATIVE_CRON_SECRET
CRON_SECRET=your-cron-secret

# GIF — composeur humain + médias NPC (https://developers.giphy.com/)
GIPHY_API_KEY=your-giphy-api-key

# Planificateur Windows / npc-schedule-run.mjs
NPC_SCHEDULE_POST_COUNT=1
NPC_SCHEDULE_COMMENT_COUNT=3

# Quota médias NPC par jour
NPC_MEDIA_MAX_PER_DAY=20

# Probabilité qu'un post NPC inclue un sondage (0–1)
NPC_POLL_CHANCE=0.12

# --- Optionnel ---

# Interrupteur global (false = désactivé, ou npm run npc:generation:off)
# NPC_GENERATION_ENABLED=true

# Tick narratif : signaux traités par exécution (défaut 3, max 5)
# NARRATIVE_SIGNALS_PER_TICK=3

# Fallback ambient si aucun signal (0–1, défaut 0.75)
# NPC_AMBIENT_FALLBACK_CHANCE=0.75

# Engagement commentaires NPC
# NPC_COMMENT_REPLY_CHANCE=0.55
# NPC_COMMENT_LIKE_CHANCE=0.75
# NPC_POST_REACTION_MIN=1
# NPC_POST_REACTION_MAX=4

# Alternative GIF : Tenor (https://tenor.com/gifapi)
# TENOR_API_KEY=

# Images IA pour posts NPC
# IMAGE_API_URL=
# IMAGE_API_KEY=
# IMAGE_API_MODEL=flux-schnell
